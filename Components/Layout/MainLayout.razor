@inherits LayoutComponentBase

@using EcoMeal.Services;
@using Microsoft.AspNetCore.Components.Authorization

@inject UserContext userContext


<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 me-2">
            <img src="favicon.png" style="width:50px; height:50px;" class="me-auto" />

            
            @if(userInfo != null)
            {
                <span>
                    Logged in as: <span class="text-@userCol">@userInfo.FullName</span>
                </span>
            }


            <a class="btn btn-outline-info" role="button" href="/users">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person" viewBox="0 0 16 16">
                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z" />
                </svg>
                Users
            </a>

            <AuthorizeView>
                <Authorized>
                    <a class="btn btn-outline-secondary" role="button" href="/api/auth/logout">
                        Logout
                    </a>
                </Authorized>
            </AuthorizeView>

            @if (isAdmin)
            {
                <a class="btn btn-outline-danger ms-2" role="button" href="/admin">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-tools" viewBox="0 0 16 16">
                        <path d="M1 0 0 1l2.2 3.081a1 1 0 0 0 .815.419h.07a1 1 0 0 1 .708.293l2.675 2.675-2.617 2.654A3.003 3.003 0 0 0 0 13a3 3 0 1 0 5.878-.851l2.654-2.617.968.968-.305.914a1 1 0 0 0 .242 1.023l3.27 3.27a.997.997 0 0 0 1.414 0l1.586-1.586a.997.997 0 0 0 0-1.414l-3.27-3.27a1 1 0 0 0-1.023-.242L10.5 9.5l-.96-.96 2.68-2.643A3.005 3.005 0 0 0 16 3q0-.405-.102-.777l-2.14 2.141L12 4l-.364-1.757L13.777.102a3 3 0 0 0-3.675 3.68L7.462 6.46 4.793 3.793a1 1 0 0 1-.293-.707v-.071a1 1 0 0 0-.419-.814zm9.646 10.646a.5.5 0 0 1 .708 0l2.914 2.915a.5.5 0 0 1-.707.707l-2.915-2.914a.5.5 0 0 1 0-.708M3 11l.471.242.529.026.287.445.445.287.026.529L5 13l-.242.471-.026.529-.445.287-.287.445-.529.026L3 15l-.471-.242L2 14.732l-.287-.445L1.268 14l-.026-.529L1 13l.242-.471.026-.529.445-.287.287-.445.529-.026z" />
                    </svg>
                    Admin
                </a>
            }

        </div>


        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    bool isAdmin = false; // one day, make some user logic pls.
    ApplicationUser? userInfo;


    protected override async Task OnInitializedAsync()
    {
        userInfo = await userContext.GetLocalUserAsync();
        if (userInfo != null)
        {
            isAdmin = await userContext.IsAdmin(userInfo);
        }
    }

    string userCol => isAdmin ? "danger" : "primary";
}