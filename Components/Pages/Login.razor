@page "/login"
@using EcoMeal.Controllers

<PageTitle>Login</PageTitle>

<h1>Login</h1>
<hr />

<div class="container mt-3">

    @if (Error is not null)
    {
        <div class="alert alert-danger" role="alert">
            ERROR: @Error
        </div>
        <hr />
    }

    <EditForm Model="@model" FormName="LoginForm" Action="/api/auth/login" Method="post" Enhance="false">
        <input type="hidden" name="returnUrl" value="@ReturnUrl" />

        <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input id="email" name="email" type="email" class="form-control" @bind-value="model.Email" />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input id="password" name="password" type="password" class="form-control" @bind-value="model.Password" />
        </div>

        <div class="mb-3 form-check">
            <input id="remember" name="remember" type="checkbox" class="form-check-input" value="true" />
            <label class="form-check-label" for="remember">Remain connected?</label>
        </div>

        <button type="submit" class="btn btn-primary">Log in</button>
    </EditForm>

    <hr class="mt-3 mb-3" />
    <p class="fs-5 fw-bold">
        No account yet? <a href="/register" class="btn btn-info text-light fw-bold" role="button">Create an account</a>
    </p>
</div>

@code {
    // Uses the mutable object approach so Blazor can read/write properties on the fly
    public EcoLoginRequest model = new();

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }
}