@page "/dashboard"
@rendermode InteractiveServer

@using EcoMeal.Entities;
@using EcoMeal.Services;
@using EcoMeal.Controllers;
@using EcoMeal.Repositories.Interfaces;
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Components.Authorization;
@using Microsoft.AspNetCore.Identity;

@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject UserContext userContext
@inject OrderController orderController
@inject WalletController walletController
@inject IWalletService walletService

@attribute [Authorize]

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard - @ActiveTab</h1>
<hr />

<AuthorizeView>
    <Authorized>
        <div class="dashboard-container">
            @* main nav *@
            <aside class="sidebar">
                <div class="sidebar-brand text-center">
                    <img src="/ecomeal_light.png" style="width: 100px; height: 100px;" alt="EcoMeal Logo">
                </div>
                <nav class="sidebar-menu">
                    <button class="menu-item @(ActiveTab == "Overview" ? "active" : "")"
                            @onclick='() => SetActiveTab("Overview")'>
                        Overview
                    </button>
                    <button class="menu-item @(ActiveTab == "Active Orders" ? "active" : "")"
                            @onclick='() => SetActiveTab("Active Orders")'>
                        Orders (@(activeOrders?.Count ?? 0))
                    </button>
                    <button class="menu-item @(ActiveTab == "Wallet" ? "active" : "")"
                            @onclick='() => SetActiveTab("Wallet")'>
                        Wallet
                    </button>
                    <button class="menu-item @(ActiveTab == "History" ? "active" : "")"
                            @onclick='() => SetActiveTab("History")'>
                        Transaction History
                    </button>
                </nav>
            </aside>

            @* split context nav *@
            <main class="main-content">
                <header class="content-header">
                    <h1>Client Management Console</h1>
                    <div class="user-profile">Welcome back, @(context.User.FindFirst("FullName")?.Value ?? "Client")</div>
                </header>

                @if (!isLoaded)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-light" role="status">
                            <span class="visually-hidden">Syncing operations...</span>
                        </div>
                        <p class="text-muted mt-2 small">Synchronizing system state with database...</p>
                    </div>
                }
                else
                {
                    @if (ActiveTab == "Overview")
                    {
                        <div class="tab-panel">
                            <section class="metrics-grid">
                                <div class="metric-card">
                                    <h3>Current Total Balance</h3>
                                    <p class="metric-value">$@CurrentBalance.ToString("F2")</p>
                                </div>
                                <div class="metric-card">
                                    <h3>Monitored Operations</h3>
                                    <p class="metric-value">@(activeOrders?.Count ?? 0) Registered Orders</p>
                                </div>
                            </section>
                            <div class="panel-card hint-box text-light">
                                <p>Select a tab from the left sidebar or click below to see orders.</p>
                                <button class="btn-primary" @onclick='() => SetActiveTab("Active Orders")'>View Active Tracking</button>
                            </div>
                        </div>
                    }
                    else if (ActiveTab == "Active Orders")
                    {
                        <div class="tab-panel">
                            <div class="panel-card">
                                <h3>Current Dispatched Orders</h3>
                                @if (activeOrders == null || !activeOrders.Any())
                                {
                                    <p class="empty-state">No active orders found. Head to the catalog to browse packages!</p>
                                }
                                else
                                {
                                    <div class="orders-list d-flex flex-column gap-3">
                                        @foreach (var order in activeOrders)
                                        {
                                            var entries = GetEntriesForOrder(order.Id);
                                            var totalCost = CalculateOrderTotal(entries);

                                            <div class="card bg-dark border border-secondary rounded-3 overflow-hidden mb-3">
                                                @* Order Row Header *@
                                                <div class="card-header border-bottom border-secondary d-flex justify-content-between align-items-center p-3" style="background-color: rgba(255, 255, 255, 0.02);">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <span class="fs-5 fw-bold text-light font-monospace">@order.OrderNumber</span>
                                                        @if (order.Business != null)
                                                        {
                                                            <span class="text-secondary small">
                                                                at
                                                                <a class="fw-bold text-light link-offset-2 link-offset-3-hover link-underline-light link-underline-opacity-0 link-underline-opacity-75-hover" href="/catalog/@order.Business.Id" target="_blank">
                                                                    @order.Business.Name <i class="bi bi-box-arrow-up-right"></i>
                                                                </a>
                                                            </span>
                                                        }
                                                    </div>
                                                    <span class="badge bg-info text-dark text-uppercase fw-bold px-2.5 py-1.5" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                                        @(order.Status?.Name ?? "Unknown")
                                                    </span>
                                                </div>

                                                @* Order Items List *@
                                                <div class="card-body p-3">
                                                    @if (entries.Any())
                                                    {
                                                        <div class="d-flex flex-column gap-2">
                                                            @foreach (var entry in entries)
                                                            {
                                                                @if (entry.Package != null)
                                                                {
                                                                    <div class="d-flex justify-content-between align-items-center py-1">
                                                                        <div class="d-flex align-items-center">
                                                                            <span class="text-secondary me-2">•</span>
                                                                            <span class="text-light fw-medium">@entry.Package.Name</span>
                                                                            <span class="badge bg-secondary text-light ms-2 px-2 py-0.5" style="font-size: 0.7rem;">Qty: @entry.Quantity</span>
                                                                        </div>
                                                                        <span class="text-secondary font-monospace">$@((entry.Package.Price * entry.Quantity).ToString("F2"))</span>
                                                                    </div>
                                                                }
                                                            }
                                                        </div>

                                                        @* Total *@
                                                        <div class="border-top border-secondary border-dashed mt-3 pt-3 d-flex justify-content-between align-items-center">
                                                            <span class="text-secondary small text-uppercase fw-semibold tracking-wider">Total Price</span>
                                                            <span class="text-success fs-4 fw-bold font-monospace">$@totalCost.ToString("F2")</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <p class="text-muted small text-center my-2">No items linked to this active dispatch row.</p>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else if (ActiveTab == "Wallet")
                    {
                        <div class="tab-panel">
                            <div class="panel-card explicit-wallet">
                                <h3>Account Wallet Handling</h3>
                                <div class="balance-display-box">
                                    <span class="label">Available Funds</span>
                                    <h2 class="wallet-funds">$@CurrentBalance.ToString("F2")</h2>
                                </div>

                                <div class="wallet-actions">
                                    <button class="btn-action success" @onclick="() => AdjustFunds(50.00m)">+ Deposit $50.00</button>
                                    <button class="btn-action success" @onclick="() => AdjustFunds(100.00m)">+ Deposit $100.00</button>
                                </div>

                                <hr class="border-secondary my-4" />

                                @* Custom Deposit Form *@
                                <div class="custom-deposit-box mt-3">
                                    <label class="text-secondary small mb-2 d-block">Custom Deposit (Max $10,000.00)</label>
                                    <div class="input-group" style="max-width: 320px;">
                                        <span class="input-group-text bg-dark text-light border-secondary">$</span>
                                        <input type="number" class="form-control bg-dark text-light border-secondary"
                                               @bind="customAmountInput"
                                               placeholder="0.00"
                                               min="0.01"
                                               max="10000.00"
                                               step="0.01" />
                                        <button class="btn btn-success fw-semibold" @onclick="DepositCustomFunds">Deposit</button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(errorMessage))
                                    {
                                        <span class="text-danger small mt-1.5 d-block">@errorMessage</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    @* Transaction History *@
                    else if (ActiveTab == "History")
                    {
                        <div class="tab-panel">
                            <div class="panel-card">
                                <h3>Verified Database Ledgers</h3>
                                <div class="table-responsive">
                                    <table class="data-table text-light">
                                        <thead>
                                            <tr>
                                                <th>TXID</th>
                                                <th>Classification</th>
                                                <th>Allocation Log</th>
                                                <th>Value Change</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (dbTransactions != null)
                                            {
                                                @foreach (var tx in dbTransactions)
                                                {
                                                    <tr>
                                                        <td><code>@tx.Id.ToString().Substring(0, 8).ToUpper()</code></td>
                                                        <td>
                                                            <span class="badge badge-@(tx.Amount >= 0 ? "deposit" : "purchase")">
                                                                @(tx.Amount >= 0 ? "Deposit" : "Purchase")
                                                            </span>
                                                        </td>
                                                        <td>@tx.Description</td>
                                                        <td class="@(tx.Amount >= 0 ? "text-success" : "text-danger")">
                                                            @(tx.Amount >= 0 ? "+" : "")$@tx.Amount.ToString("F2")
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                }
            </main>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private string ActiveTab { get; set; } = "Overview";
    private Wallet? userWallet;
    private decimal CurrentBalance => userWallet?.Balance ?? 0.00m;
    private bool isLoaded = false;

    private ApplicationUser? user;
    private List<Order>? activeOrders;
    private Dictionary<Guid, List<OrderEntry>> orderEntriesMap = new();

    private List<WalletTransaction>? dbTransactions;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        isLoaded = false;
        user = await userContext.GetLocalUserAsync();
        if (user is null)
            return;

        if (Guid.TryParse(user.Id, out var userId))
        {
            var walletResult = await walletController.GetUserWallet(userId);
            Console.WriteLine("Frontend wallet fetch result: " + (walletResult != null ? "Success" : "No wallet found"));

            userWallet = walletResult?.Value;

            Console.WriteLine("Wallet true value: " + (userWallet != null ? "Exists!!!\n\n" : "Null. May your soul rest in pieces, Mirai.\n\n"));

            if (userWallet != null)
            {
                var txList = await walletService.GetTransactionHistoryAsync(userWallet.Id);
                dbTransactions = txList?.ToList() ?? new List<WalletTransaction>();
            }
        }

        var result = await orderController.GetUserOrders(user);
        activeOrders = result?.Value;

        if (activeOrders != null)
        {
            orderEntriesMap.Clear();
            foreach (var order in activeOrders)
            {
                var entries = order.OrderEntries;
                orderEntriesMap[order.Id] = entries ?? new List<OrderEntry>();
            }
        }

        isLoaded = true;
    }

    private List<OrderEntry> GetEntriesForOrder(Guid orderId)
    {
        return orderEntriesMap.TryGetValue(orderId, out var entries) ? entries : new List<OrderEntry>();
    }

    private double CalculateOrderTotal(List<OrderEntry> entries)
    {
        if (entries == null) return 0.0;
        return entries.Where(e => e.Package != null).Sum(e => e.Package.Price * e.Quantity);
    }

    private void SetActiveTab(string tabName)
    {
        ActiveTab = tabName;
        StateHasChanged();
    }

    private async Task AdjustFunds(decimal amount)
    {
        if (userWallet == null) return;

        var successResult = await walletController.AdjustBalance(userWallet.Id, amount, "Added funds via Service Portal");

        if (successResult?.Value == true)
        {
            var txs = await walletService.GetTransactionHistoryAsync(userWallet.Id);
            dbTransactions = txs?.ToList() ?? new List<WalletTransaction>();
        }
    }

    private decimal? customAmountInput; // for funds
    private string? errorMessage;

    private async Task DepositCustomFunds()
    {
        errorMessage = null;

        if (customAmountInput == null || customAmountInput <= 0)
        {
            errorMessage = "Please enter a valid positive amount.";
            return;
        }

        if (customAmountInput > 10000.00m)
        {
            errorMessage = "Deposits are capped at $10,000.00 at a time.";
            return;
        }

        decimal amountToDeposit = customAmountInput.Value;
        await AdjustFunds(amountToDeposit);
        customAmountInput = null;
    }
}