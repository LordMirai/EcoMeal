@page "/catalog/{id}"
@rendermode InteractiveServer

@using EcoMeal.Entities;
@using EcoMeal.Controllers;
@using EcoMeal.Services;
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Mvc;
@using Bogus


@inject BusinessController businessController
@inject PackageController packageController
@inject OrderController orderController
@inject UserContext userContext



<PageTitle>Catalog @(error ? "- Error" : "")</PageTitle>

<h3>@headName</h3>
<hr />

@if (error)
{
    <div class="container mt-5" style="max-width: 600px;">
        <div class="card shadow-sm border-0 border-start border-danger border-4">
            <div class="card-body p-4 text-center">
                <i class="bi bi-exclamation-octagon fs-1 text-danger mb-2"></i>
                <h4 class="fw-bold text-dark">Catalog Error</h4>

                <p class="text-secondary small" title="Bad ID">
                    The requested Business ID <code class="bg-light p-1 rounded">@id</code> is malformed or business could not be found.
                </p>
                <a href="/businesses" class="btn btn-outline-secondary btn-sm px-4">
                    <i class="bi bi-arrow-left me-2"></i>Return to Business list
                </a>
            </div>
        </div>
    </div>
    return;
}




@* Admin control for bogus gen *@
<AuthorizeView Roles="admin">
    <Authorized>
        <div class="card shadow-sm border-0 mb-4 rounded-3 admin-generator-bar">
            <div class="card-body p-3 d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-shield-lock-fill text-warning fs-5"></i>
                    <div>
                        <span class="fw-bold text-dark fs-5">Administrative Tools</span>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <div class="d-flex align-items-center gap-2 border-end pe-3 me-2">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-white text-secondary small">Quantity</span>
                            <input type="number" class="form-control qty-input-width" min="1" max="100" @bind="packagesToGen" />
                        </div>
                        <button type="button" role="button" class="btn btn-sm btn-warning fw-semibold px-2 text-dark shadow-sm" @onclick="GenerateMockPackages">
                            Generate
                        </button>
                    </div>

                    <button type="button" role="button" class="btn btn-sm btn-outline-danger fw-semibold px-3" @onclick="WipeAllPackages">
                        <i class="bi bi-trash3-fill me-1"></i> Purge Catalog
                    </button>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>



@if (currentBusiness != null)
{
    <div class="container mt-4">
        @* Apparently, this is called "Split Hero Header Banner" *@
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden mb-4 bg-light">
            <div class="row g-0 align-items-center">
                <div class="col-sm-4 col-md-3 text-center p-3 bg-white border-end">
                    <img src="@currentBusiness.ImageURL"
                         class="rounded-3 shadow-sm object-fit-cover w-100"
                         style="max-height: 180px; aspect-ratio: 1/1;"
                         alt="@currentBusiness.Name Profile" />
                </div>
                <div class="col-sm-8 col-md-9 p-4">
                    <span class="text-uppercase tracking-wider text-primary fw-bold small d-block mb-1">Catalog Registry</span>
                    <h1 class="fw-bold text-dark h2 mb-2">@currentBusiness.Name</h1>
                    <p class="text-muted small mb-3">
                        <i class="bi bi-box-seam me-1 text-secondary"></i> Managing <span class="fw-semibold text-dark">@(packages?.Count ?? 0)</span> active package listings.
                    </p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-primary fw-semibold btn-sm shadow-sm px-3" href="/create-package/@BusinessID">
                            <i class="bi bi-plus-lg me-2"></i>Create New Package
                        </a>
                        <a class="btn btn-outline-secondary btn-sm px-3" href="/businesses">
                            <i class="bi bi-arrow-left me-1"></i>Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @* Search box and filter by categ *@
        <div class="row g-2 mb-4">
            <div class="col-md-8">
                <div class="input-group">
                    <span class="input-group-text bg-white text-secondary border-end-0">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" class="form-control border-start-0 ps-0"
                           placeholder="Search packages by Name or ID"
                           @bind="searchQuery" @bind:event="oninput" />
                </div>
            </div>

            <div class="col-md-4">
                <select class="form-select" @bind="selectedTypeId">
                    <option value="">All Categories</option>
                    @if (packageTypes != null)
                    {
                        @foreach (var type in packageTypes)
                        {
                            <option value="@type.Id.ToString()">@type.Name</option>
                        }
                    }
                </select>
            </div>
        </div>


        @if ((packages?.Count ?? 0) == 0)
        {
            <div class="card border-0 shadow-sm p-5 text-center bg-white rounded-3">
                <div class="py-4">
                    <i class="bi bi-inbox-fill text-muted fs-1 mb-3 d-block"></i>
                    <h5 class="fw-bold text-dark">Empty Inventory</h5>
                    <p class="text-secondary small mx-auto" style="max-width: 400px;">
                        This business hasn't published any items to their catalog yet. Use the action panel above to configure a package.
                    </p>
                </div>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (Package pkg in FilteredPackages)
                {
                    var isOutOfStock = pkg.Quantity <= 0;
                    var isLowStock = pkg.Quantity > 0 && pkg.Quantity <= 5;

                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden position-relative transition-hover @(isOutOfStock ? "opacity-75 bg-light" : "")">
                            <div class="position-relative bg-secondary-subtle" style="height: 200px;">
                                <img src="@pkg.ImageURL"
                                     class="w-100 h-100 object-fit-cover @(isOutOfStock ? "grayscale-filter" : "")"
                                     alt="@pkg.Name Picture" />

                                @if (isOutOfStock)
                                {
                                    <div class="position-absolute inset-0 bg-dark bg-opacity-50 d-flex align-items-center justify-content-center">
                                        <span class="badge bg-danger text-uppercase fw-bold px-3 py-2 fs-6 shadow">Sold Out</span>
                                    </div>
                                }
                                else if (isLowStock)
                                {
                                    <span class="position-absolute badge bg-warning text-dark fw-bold shadow-sm" style="top: 10px; right: 10px; z-index: 10;">
                                        Only @pkg.Quantity Left!
                                    </span>
                                }
                            </div>

                            <div class="card-body p-4 d-flex flex-column">
                                @if (pkg.PackageType != null)
                                {
                                    <div class="mb-2">
                                        <span class="badge badge-outline-category text-uppercase tracking-wider">
                                            @pkg.PackageType.Name
                                        </span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h4 class="card-title fw-bold text-dark fs-5 mb-0 text-truncate" title="@pkg.Name">
                                        @pkg.Name
                                    </h4>
                                    <span class="fs-5 fw-bold text-success ps-2">
                                        $@pkg.Price.ToString("F2")
                                    </span>
                                </div>

                                <p class="text-secondary small mb-4 text-truncate-3 flex-grow-1" style="font-size: 0.875rem; line-height: 1.5;">
                                    @pkg.Description
                                </p>

                                <AuthorizeView Context="_unused">
                                    <Authorized>


                                        <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-auto w-100">
                                            <span class="small text-muted">
                                                <i class="bi bi-stack me-1"></i> Stock:
                                                <span class="fw-semibold @(isOutOfStock ? "text-danger" : "text-dark")">@pkg.Quantity pcs</span>
                                            </span>

                                            <div class="d-flex gap-2">
                                                @* Order layout will go here someday. *@
                                                <button class="btn btn-sm btn-outline-primary fw-semibold px-3" disabled="@isOutOfStock" @onclick="() => OpenAddToCartModal(pkg)">
                                                    <i class="bi bi-cart-plus"></i>
                                                </button>

                                                <AuthorizeView Roles="admin">
                                                    <Authorized>
                                                        <a href="/create-package/edit/@pkg.Id" class="btn btn-sm btn-warning text-dark fw-medium px-3" role="button" title="Modify Package Metadata">
                                                            Edit <i class="bi bi-pencil-square ms-1"></i>
                                                        </a>
                                                        <button type="button" role="button" class="btn btn-sm btn-danger px-3 transition-danger-btn"
                                                                @onclick="() => DeletePackage(pkg)" title="Permanently Delete Package">
                                                            <i class="bi bi-trash3"></i>
                                                        </button>
                                                    </Authorized>
                                                </AuthorizeView>
                                            </div>
                                        </div>

                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}



@* "Add to cart" modal *@
@if (showModal && selectedPackage != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5);" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content border-0 shadow rounded-3">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-dark">Add Package to Cart</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body py-4">
                    <div class="text-center mb-3">
                        <span class="text-muted small d-block mb-1">Target Package</span>
                        <h6 class="fw-bold text-primary mb-0">@selectedPackage.Name</h6>
                    </div>

                    <div class="d-flex align-items-center justify-content-center gap-3 mb-4">
                        <button type="button" class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;" @onclick="DecrementQty" disabled="@(selectedQty <= 1)">
                            <i class="bi bi-dash-lg"></i>
                        </button>

                        <div class="text-center" style="min-width: 60px;">
                            <span class="fs-3 fw-bold text-dark">@selectedQty</span>
                            <span class="text-muted small d-block">units</span>
                        </div>

                        <button type="button" class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;" @onclick="IncrementQty" disabled="@(selectedQty >= selectedPackage.Quantity)">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>

                    <div class="px-3 mb-4">
                        <input type="range" class="form-range custom-slider" min="1" max="@selectedPackage.Quantity" @bind="selectedQty" @bind:event="oninput" />
                        <div class="d-flex justify-content-between small text-muted mt-1">
                            <span>1</span>
                            <span>Max Available: @selectedPackage.Quantity</span>
                        </div>
                    </div>

                    <div class="bg-light rounded-3 p-3 text-center mx-2 shadow-sm border">
                        <span class="text-secondary small d-block mb-1">Calculated Total Estimate</span>
                        <h4 class="fw-bold text-success mb-0">$@((selectedPackage.Price * selectedQty).ToString("F2"))</h4>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light fw-semibold px-4" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="btn btn-primary fw-semibold px-4 shadow-sm" @onclick="SubmitAddToCart">
                        <i class="bi bi-cart-check-fill me-2"></i>Add to Cart
                    </button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    [Parameter]
    public string id { get; set; }
    Guid BusinessID;

    private Business? currentBusiness;

    private Guid? selectedTypeId;
    private string searchQuery = string.Empty;

    bool error = false;
    string headName => error ? "Catalog - Error - Bad ID" : $"Catalog for {currentBusiness?.Name}";

    private ApplicationUser? currentUser;

    // Modal Control State
    private bool showModal = false;
    private Package? selectedPackage;
    private int selectedQty = 1;

    private List<PackageType>? packageTypes = new();
    private List<Package>? packages = new();
    private List<Package>? FilteredPackages
    {
        get
        {
            if (packages == null) return new List<Package>();

            var result = packages.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                result = result.Where(p =>
                    p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.Id.ToString().Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(selectedTypeId.ToString()))
            {
                result = result.Where(p => p.PackageType != null && p.PackageType.Id.ToString() == selectedTypeId.ToString());
            }

            return result.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        packageTypes = await packageController.GetTypesAsync();


        try
        {
            BusinessID = Guid.Parse(id);
        }
        catch (FormatException)
        {
            error = true;
            return;
        }

        currentUser = await userContext.GetLocalUserAsync();

        // Console.WriteLine($"Catalog ID: {BusinessID}");

        ActionResult<Business?> result = await businessController.GetById(BusinessID);
        if (result.Result is NotFoundResult)
        {
            error = true;
            return;
        }


        currentBusiness = result.Value;

        ActionResult<List<Package>> packageResult = await packageController.GetByBusinessIdAsync(BusinessID);
        packages = packageResult.Value;
    }

    // modal stuff
    private void OpenAddToCartModal(Package pkg)
    {
        selectedPackage = pkg;
        selectedQty = 1; // Reset allocation sequence
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        selectedPackage = null;
    }

    private void IncrementQty()
    {
        if (selectedPackage != null && selectedQty < selectedPackage.Quantity)
        {
            selectedQty++;
        }
    }

    private void DecrementQty()
    {
        if (selectedQty > 1)
        {
            selectedQty--;
        }
    }

    private async Task SubmitAddToCart()
    {
        if (selectedPackage == null) return;

        Console.WriteLine($"Adding {selectedQty} of {selectedPackage.Name} to cart.");

        if (currentUser == null)
        {
            Console.WriteLine("User not logged in. Cannot add to cart.");
            CloseModal();
            return;
        }

        Console.WriteLine("For my own sanity. DO we have the valid business?");
        Console.WriteLine($"{selectedPackage.Business.Name}");

        var result = await orderController.AddToCart(Guid.Parse(currentUser.Id), selectedPackage, selectedQty);

        CloseModal();
    }
}


@* Bogus pkg gen *@
@code {
    private int packagesToGen = 5;

    private async Task GenerateMockPackages()
    {
        // Console.WriteLine("Func is called!!!");
        if (packagesToGen <= 0) return;
        var faker = new Faker();

        // Console.WriteLine($"Bogus is generating {packagesToGen} packages...");

        for (int i = 0; i < packagesToGen; i++)
        {
            var mockPackage = new Package
                {
                    Id = Guid.NewGuid(),
                    Name = $"{faker.Commerce.ProductAdjective()} {faker.Commerce.ProductName()}",
                    Description = faker.Commerce.ProductDescription(),
                    Price = float.Parse(faker.Commerce.Price(min: 5, max: 45, decimals: 2)),
                    Quantity = faker.Random.Int(min: 1, max: 25),
                    ImageURL = faker.Image.PicsumUrl(640, 480, false),
                    Business = currentBusiness,
                    PackageType = faker.PickRandom(packageTypes)
                };

            // Console.WriteLine($"Package: {mockPackage.Name}, Price: {mockPackage.Price}, Quantity: {mockPackage.Quantity}");
            await packageController.AddAsync(mockPackage);
        }

        ActionResult<List<Package>> packageResult = await packageController.GetByBusinessIdAsync(BusinessID);
        packages = packageResult.Value;
    }



    private async Task WipeAllPackages()
    {
        if (packages == null || !packages.Any())
        {
            return;
        }

        var totalToPurge = packages.Count;

        foreach (var pkg in packages)
        {
            await packageController.DeleteAsync(pkg.Id);
        }

        ActionResult<List<Package>> packageResult = await packageController.GetByBusinessIdAsync(BusinessID);
        packages = packageResult.Value;
    }

    private async Task DeletePackage(Package pkg)
    {
        if (pkg == null)
        {
            return;
        }
        await packageController.DeleteAsync(pkg.Id);
        ActionResult<List<Package>> packageResult = await packageController.GetByBusinessIdAsync(BusinessID);
        packages = packageResult.Value;
    }
}